from functools import wraps
from time import time


def logger(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        print(f"\nCalling: {func.__name__}")
        result = func(*args, **kwargs)
        print(f"Finished: {func.__name__}")
        return result
    return wrapper


def timer(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        start = time()
        result = func(*args, **kwargs)
        end = time()
        print(f"Execution Time: {end - start:.6f} sec")
        return result
    return wrapper


@logger
@timer
def calculate_sum(n):
    return sum(range(1, n + 1))


@logger
def greet(name):
    print(f"Hello, {name}!")


print(calculate_sum(1000000))
greet("Akansha")
